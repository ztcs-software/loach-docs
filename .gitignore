# Test / coverage output (defensive)
coverage/
.nyc_output/

# Deployment-platform local caches (defensive)
.vercel/
.netlify/
.firebase/

# Python (we use inline Python heredocs for bulk page edits; keeps caches out if they ever land)
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Local SSL / dev certs
*.pem
*.key
*.crt

# Environment / secrets — defensive, none are expected to live here
.env
.env.*
!.env.example

# Local-only overrides (drop-in files for per-developer experiments, never committed)
local.css
local.js
local.html

# Archives & exports — none are part of the site itself
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
